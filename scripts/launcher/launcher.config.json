{
  "appName": "VySol",
  "browserUrl": "http://127.0.0.1:8000/health",
  "readyTimeoutSeconds": 60,
  "services": [
    {
      "name": "frontend",
      "enabled": false,
      "workingDirectory": ".",
      "command": "npm",
      "arguments": ["run", "dev", "--", "--host", "127.0.0.1", "--port", "5173"],
      "requiredPort": 5173,
      "healthUrl": "http://127.0.0.1:5173",
      "commandFingerprint": "dev"
    },
    {
      "name": "backend",
      "enabled": true,
      "workingDirectory": ".",
      "command": ".venv/Scripts/python.exe",
      "arguments": ["-m", "uvicorn", "app.main:app", "--host", "127.0.0.1", "--port", "8000"],
      "requiredPort": 8000,
      "healthUrl": "http://127.0.0.1:8000/health",
      "commandFingerprint": "uvicorn"
    }
  ],
  "todos": [
    "Confirm final frontend command, ports, and health checks once UI work starts.",
    "Keep requiredPort and healthUrl aligned with the app's real runtime configuration."
  ]
}
