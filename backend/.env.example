# Optional fallback API key for local development.
# You can also add provider credentials later in the app settings UI instead.
GEMINI_API_KEY=
GROQ_API_KEY=
INTENSERP_BASE_URL=http://127.0.0.1:7777/v1

# Comma-separated list of frontend origins allowed to call the backend.
# Leave blank to use the local development defaults.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://[::1]:3000
